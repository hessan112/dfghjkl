name: ChromeOS-Hatch-AutoPerformance

on:
  workflow_dispatch:

jobs:
  build-and-run:
    runs-on: ubuntu-latest
    steps:
      - name: 1. Maximize Server Performance
        run: |
          # تنظيف شامل للسيرفر لتسريع الهارد والرامات
          sudo rm -rf /usr/share/dotnet /usr/local/lib/android /opt/ghc
          sudo docker image prune -a -f

      - name: 2. Install Essentials
        run: |
          sudo apt update && sudo apt install -y unzip tar pv jq qemu-kvm qemu-utils

      - name: 3. Download Unified Package from Drive
        run: |
          # تحميل الملف المدمج الذي يحتوي على المكونات
          curl -L "https://drive.google.com/uc?export=download&id=19eWMfDpelImZVh-W8H9gn_F7kqLJwexG" -o package.zip

      - name: 4. Extract and Build System Image
        run: |
          echo "Extracting Unified Package..."
          unzip package.zip
          
          # فك ضغط المحتويات تلقائياً مهما كان اسمها
          find . -name "*.tar.gz" -exec tar -xvf {} \;
          find . -name "chromeos_*.zip" -exec unzip {} \;
          
          echo "Building Official Image (Hatch)..."
          sudo bash chromeos-install.sh -src *.bin -dst chromeos.img

      - name: 5. Connect Tailscale
        uses: tailscale/github-action@v2
        with:
          authkey: ${{ secrets.TS_AUTHKEY }}

      - name: 6. Intelligent Auto-RAM Launch
        run: |
          # حساب الرامات المتاحة وتخصيصها ديناميكياً (Auto RAM)
          TOTAL_RAM=$(free -g | awk '/^Mem:/{print $2}')
          # نترك 1 جيجا فقط لنظام GitHub والباقي للـ Chromebook
          ALLOCATED_RAM=$((TOTAL_RAM - 1))
          
          echo "Server RAM: ${TOTAL_RAM}G | Allocated to ChromeOS: ${ALLOCATED_RAM}G"

          # تشغيل النظام مع تحسينات السرعة (Virtio) لتسريع الإقلاع
          docker run -d --name chromeos --device /dev/kvm -p 3389:3389 \
          -v $(pwd)/chromeos.img:/image/chromeos.img \
          -e RAM=${ALLOCATED_RAM} \
          -e CORES=$(nproc) \
          -e EXTRA="-vga virtio -display none -usb -device usb-tablet" \
          sickcodes/docker-chromeos:latest

      - name: 7. Final Connection Info
        run: |
          echo "===================================================="
          echo "✅ تم التشغيل بأقصى أداء متاح للسيرفر!"
          echo "🔗 رابط الـ IP الخاص بك (اتصل عبر RDP):"
          tailscale ip -4
          echo "===================================================="

      - name: 8. Keep Session Alive
        run: while true; do sleep 300; done
